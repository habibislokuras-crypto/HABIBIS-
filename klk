    return _G.Noclip
end)

RS.Stepped:Connect(function()
    if _G.Noclip and LP.Character then
        for _, p in pairs(LP.Character:GetDescendants()) do
            if p:IsA("BasePart") and p.CanCollide == true then 
                p.CanCollide = false 
            end
        end
    end
end)