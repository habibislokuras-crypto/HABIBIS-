<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>STREET_DOMIONS</title>
  <style>
    body {
      background-color: #000;
      color: #a020f0; /* morado */
      font-family: monospace;
      text-align: center;
      margin-top: 10%;
    }
    h1 {
      font-size: 3em;
      border: 2px solid #a020f0;
      display: inline-block;
      padding: 10px 20px;
      margin-bottom: 30px;
    }
    .login-box {
      border: 2px solid #a020f0;
      display: inline-block;
      padding: 20px;
      text-align: left;
    }
    label {
      display: block;
      margin: 10px 0 5px;
    }
    input {
      width: 100%;
      padding: 8px;
      background: #111;
      border: 1px solid #a020f0;
      color: #a020f0;
    }
    button {
      margin-top: 15px;
      width: 100%;
      padding: 10px;
      background: #a020f0;
      color: #000;
      font-weight: bold;
      border: none;
      cursor: pointer;
    }
    button:hover {
      background: #fff;
      color: #000;
    }
  </style>
</head>
<body>
  <h1>STREET_DOMIONS</h1>
  <p>SISTEMA DE CONTROL DE VENDEDORES</p>
  
  <div class="login-box">
    <label for="usuario">USUARIO</label>
    <input type="text" id="usuario" name="usuario" value="FAMILY_XIT">
    
    <label for="password">CONTRASEÑA</label>
    <input type="password" id="password" name="password" value="XIT_VITION">
    
    <button>AUTENTICAR SISTEMA</button>
  </div>
</body>
</html>
